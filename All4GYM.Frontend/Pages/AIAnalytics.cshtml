@page "{handler?}"
@using System.Text.Json
@model All4GYM.Frontend.Pages.AIAnalyticsModel
@{
    ViewData["Title"] = "AI Аналітика прогресу";
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm">
                <h4 class="mb-3">🧠 Запустити AI Аналіз</h4>
                
                <div class="mb-3">
                    <label class="form-label">Напрямок аналізу</label>
                    <select id="vectorType" class="form-select">
                        <option value="Nutrition">🍏 Аналіз харчування та ваги</option>
                        <option value="Workout">🏋️‍♂️ Аналіз тренувань та прогресії</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Період даних</label>
                    <select id="daysPeriod" class="form-select">
                        <option value="7">За останні 7 днів</option>
                        <option value="30">За останні 30 днів</option>
                        <option value="90">За останні 90 днів</option>
                    </select>
                </div>

                <button type="button" id="btnAnalyze" class="btn btn-primary w-100">
                    🚀 INITIALIZE ANALYSIS
                </button>
                
                <div class="mt-4">
    <h5 class="mb-2">📋 Попередні звіти</h5>
    
    <div class="btn-group btn-group-sm w-100 mb-2" role="group" id="historyFilters">
        <button type="button" class="btn btn-outline-primary active" data-filter="all">Усі</button>
        <button type="button" class="btn btn-outline-primary" data-filter="Nutrition">🍏 Харчування</button>
        <button type="button" class="btn btn-outline-primary" data-filter="Workout">🏋️‍♂️ Тренування</button>
    </div>

    <div class="list-group overflow-auto shadow-sm border rounded" style="max-height: 240px;" id="historyList">
        @foreach (var review in Model.WorkoutHistory)
        {
            <button class="list-group-item list-group-item-action history-item" 
                    data-vector="Workout"
                    data-overview="@review.Overview" 
                    data-trend="@review.TrendPrediction"
                    data-recommendations="@JsonSerializer.Serialize(review.Recommendations)"
                    data-id="@review.Id">
                🏋️‍♂️ Звіт від @review.GeneratedAt.ToString("dd.MM.yyyy HH:mm")
            </button>
        }
        
        @foreach (var review in Model.NutritionHistory)
        {
            <button class="list-group-item list-group-item-action history-item" 
                    data-vector="Nutrition"
                    data-overview="@review.Overview" 
                    data-trend="@review.TrendPrediction"
                    data-recommendations="@JsonSerializer.Serialize(review.Recommendations)"
                    data-id="@review.Id">
                🍏 Звіт від @review.GeneratedAt.ToString("dd.MM.yyyy HH:mm")
            </button>
        }

        @if (!Model.NutritionHistory.Any() && !Model.WorkoutHistory.Any())
        {
            <div class="text-center text-muted py-3 bg-light">Історія порожня</div>
        }
    </div>
</div>
            </div>
        </div>

        <div class="col-md-8">
            <div id="aiLoader" class="text-center my-5" style="display: none;">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
                <p class="mt-3 text-muted animate-pulse">Gemini аналізує ваші тренувальні щоденники...</p>
            </div>

            <div id="aiResultCard" class="card p-4 shadow-sm" style="min-height: 450px;">
                <div id="placeholderContent" class="text-center my-auto">
                    <h3 class="text-muted">Оберіть параметри та запустіть аналіз</h3>
                    <p class="text-muted">ІІ згенерує персональний огляд, знайде помилки та спрогнозує тренд.</p>
                </div>

                <div id="analysisOutput" style="display: none;">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="text-primary mb-0">✨ Персональний ІІ-Огляд</h3>
                        <div id="feedbackBlock" class="d-flex gap-2">
                            <button id="btnLike" class="btn btn-sm btn-outline-success">👍 Корисно</button>
                            <button id="btnDislike" class="btn btn-sm btn-outline-danger">👎 Не підходить</button>
                        </div>
                    </div>

                    <h5 class="mt-3">📝 Загальний висновок</h5>
                    <p id="lblOverview" class="text-justify border-start border-primary border-3 ps-3 py-1 bg-light"></p>

                    <h5 class="mt-4">🎯 Тактичні рекомендації</h5>
                    <ul id="listRecommendations" class="list-group list-group-flush mb-3"></ul>

                    <h5 class="mt-4">📈 Прогноз та Тренд</h5>
                    <div class="p-3 bg-dark text-light rounded font-monospace" id="lblTrend"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
const currentReview = { id: 0 };
const xsrfToken = '@tokens.RequestToken';
document.getElementById('btnAnalyze').addEventListener('click', async () => {
    const vectorType = document.getElementById('vectorType').value;
    const days = parseInt(document.getElementById('daysPeriod').value);
    
    document.getElementById('placeholderContent').style.display = 'none';
    document.getElementById('analysisOutput').style.display = 'none';
    document.getElementById('aiLoader').style.display = 'block';
    document.getElementById('btnAnalyze').disabled = true;

    try {
        const response = await fetch('/AIAnalytics?handler=GenerateReview', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': xsrfToken
            },
            body: JSON.stringify({
                periodDays: days,
                vectorType: vectorType
            })
        });

        if (!response.ok) {
            const errorDetails = await response.text();
            console.error('Full error:', response.status, errorDetails);
            throw new Error(`Backend Error: ${response.status} - ${errorDetails}`);
        }

        const data = await response.json();
        renderReview(data);
        document.querySelectorAll('.history-item').forEach(i => i.classList.remove('active'));

    } catch (error) {
        console.error('Помилка генерації аналізу:', error);
        alert(error.message);
        document.getElementById('placeholderContent').style.display = 'block';
    } finally {
        document.getElementById('aiLoader').style.display = 'none';
        document.getElementById('btnAnalyze').disabled = false;
    }
});

function renderReview(data) {
    currentReview.id = data.id;
    
    document.getElementById('lblOverview').innerText = data.overview || "Огляд відсутній";
    document.getElementById('lblTrend').innerText = data.trendPrediction || "Немає прогнозу";
    
    const list = document.getElementById('listRecommendations');
    list.innerHTML = '';

    const recs = data.recommendations ?? [];
    if (recs.length === 0) {
        const li = document.createElement('li');
        li.className = 'list-group-item ps-0 border-0 text-muted';
        li.innerText = 'Рекомендації відсутні';
        list.appendChild(li);
    } else {
        recs.forEach(rec => {
            const li = document.createElement('li');
            li.className = 'list-group-item ps-0 border-0 text-justify';
            li.innerHTML = `🔹 ${rec}`;
            list.appendChild(li);
        });
    }
    
    document.getElementById('feedbackBlock').style.display = currentReview.id > 0 ? 'flex' : 'none';
    document.getElementById('analysisOutput').style.display = 'block';
}

document.querySelectorAll('.history-item').forEach(btn => {
    btn.addEventListener('click', (e) => {
        const t = e.currentTarget;
        document.querySelectorAll('.history-item').forEach(i => i.classList.remove('active'));
        t.classList.add('active');

        try {
            let recommendationsArray = [];
            const rawRecs = t.dataset.recommendations;
            if (rawRecs && rawRecs.trim() !== "") {
                recommendationsArray = JSON.parse(rawRecs);
            }

            const data = {
                id: parseInt(t.dataset.id) || 0,
                overview: t.dataset.overview,
                trendPrediction: t.dataset.trend || t.dataset.trendPrediction,
                recommendations: recommendationsArray
            };

            document.getElementById('placeholderContent').style.display = 'none';
            renderReview(data);

        } catch (error) {
            console.error("Помилка парсингу даних з історії:", error);
            alert("Не вдалося завантажити звіт з історії через помилку формату даних.");
        }
    });
});

document.querySelectorAll('#historyFilters button').forEach(tab => {
    tab.addEventListener('click', (e) => {
        // Переключение активного визуального класса на вкладках
        document.querySelectorAll('#historyFilters button').forEach(b => b.classList.remove('active'));
        e.currentTarget.classList.add('active');

        const filterValue = e.currentTarget.dataset.filter;
        const items = document.querySelectorAll('#historyList .history-item');

        items.forEach(item => {
            if (filterValue === 'all') {
                item.style.setProperty('display', 'block', 'important');
            } else {
                if (item.dataset.vector === filterValue) {
                    item.style.setProperty('display', 'block', 'important');
                } else {
                    item.style.setProperty('display', 'none', 'important');
                }
            }
        });
    });
});

async function sendFeedback(isHelpful) {
    if (currentReview.id === 0) return;

    try {
        const response = await fetch('/AIAnalytics?handler=SubmitFeedback', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': xsrfToken
            },
            body: JSON.stringify({
                aiReviewId: currentReview.id,
                isHelpful: isHelpful
            })
        });

        if (!response.ok) {
            const text = await response.text();
            throw new Error(text || "Server error");
        }
        
        document.getElementById('feedbackBlock').style.display = 'none';
        alert('Дякуємо за відгук!');

    } catch (error) {
        console.error('Помилка відправки відгуку:', error);
        alert(error.message || 'Не вдалося зберегти відгук.');
    }
}

document.getElementById('btnLike').addEventListener('click', () => sendFeedback(true));
document.getElementById('btnDislike').addEventListener('click', () => sendFeedback(false));
</script>