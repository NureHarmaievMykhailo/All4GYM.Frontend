@page
@model MealLogModel
@{
    ViewData["Title"] = "Харчовий щоденник";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🍽️ Харчовий щоденник</h2>
        <div class="d-flex gap-2">
            <button type="button" id="btnAiAnalyzeNutrition" class="btn btn-primary bg-gradient text-white border-0 shadow-sm px-4">
                ✨ AI-Аналіз дня
            </button>
            <a asp-page="/NutritionCalculator" class="btn btn-outline-primary">
                🔢 Розрахувати денну норму калорій
            </a>
        </div>
    </div>
    
    <div id="aiNutritionResult" class="card shadow-lg border-0 rounded-4 mb-4" style="display: none; overflow: hidden;">
        <div class="card-header bg-gradient bg-primary text-white p-3">
            <h5 class="mb-0">🤖 Персональний AI-Нутриціолог</h5>
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="h-100 p-3 bg-white rounded-3 shadow-sm border-start border-4 border-info">
                        <h6 class="text-info fw-bold mb-2">⚖️ Баланс КБЖУ</h6>
                        <p id="aiBalanceVerdict" class="text-muted small mb-0">Завантаження...</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="h-100 p-3 bg-white rounded-3 shadow-sm border-start border-4 border-warning">
                        <h6 class="text-warning fw-bold mb-2">🔬 Аналіз нутрієнтів</h6>
                        <p id="aiMicronutrientsNotes" class="text-muted small mb-0">Завантаження...</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="h-100 p-3 bg-white rounded-3 shadow-sm border-start border-4 border-success">
                        <h6 class="text-success fw-bold mb-2">💡 Наступний прийом</h6>
                        <p id="aiRecommendationForDinner" class="text-dark fw-medium small mb-0">Завантаження...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">Дата</label>
            <input type="date" id="selectedDateInput" name="SelectedDate" value="@Model.SelectedDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="d-flex gap-3 mb-4">
            <a class="btn btn-primary" asp-page="/FoodItems">➕Додати новий продукт</a>
            <a class="btn btn-outline-success" href="/HealthyRecipes">🥗ПХ Рецепти</a>
        </div>

        <div class="col-md-4">
            <label class="form-label">Тип прийому їжі</label>
            <select name="SelectedMealType" class="form-select">
                <option value="" selected="@(string.IsNullOrEmpty(Model.SelectedMealType))">Усі</option>
                <option value="Breakfast" selected="@("Breakfast" == Model.SelectedMealType)">Сніданок</option>
                <option value="Lunch" selected="@("Lunch" == Model.SelectedMealType)">Обід</option>
                <option value="Dinner" selected="@("Dinner" == Model.SelectedMealType)">Вечеря</option>
                <option value="Snack" selected="@("Snack" == Model.SelectedMealType)">Перекус</option>
            </select>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button class="btn btn-outline-primary" type="submit">🔍 Пошук</button>
        </div>
    </form>

    <hr />

    <form method="post" asp-page="/MealLog" class="row g-3 mb-4">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-4">
            <label asp-for="NewEntry.FoodItemId" class="form-label">Продукт</label>
            <select asp-for="NewEntry.FoodItemId" class="form-select">
                <option value="">-- Оберіть --</option>
                @foreach (var item in Model.FoodItems)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="NewEntry.Grams" class="form-label">Вага (г)</label>
            <input asp-for="NewEntry.Grams" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="NewEntry.MealType" class="form-label">Прийом їжі</label>
            <select asp-for="NewEntry.MealType" class="form-select">
                <option value="Breakfast">Сніданок</option>
                <option value="Lunch">Обід</option>
                <option value="Dinner">Вечеря</option>
                <option value="Snack">Перекус</option>
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-success" type="submit">➕ Додати</button>
        </div>
    </form>

    @if (Model.Entries.Any())
    {
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Прийом їжі</th>
                    <th>Продукт</th>
                    <th>Вага (г)</th>
                    <th>Ккал</th>
                    <th>Білки</th>
                    <th>Жири</th>
                    <th>Вугл.</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.Entries)
                {
                    <tr>
                        <td>@entry.MealType</td>
                        <td>@entry.FoodItemName</td>
                        <td>@entry.Grams</td>
                        <td>@entry.Calories</td>
                        <td>@entry.Proteins</td>
                        <td>@entry.Fats</td>
                        <td>@entry.Carbs</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@entry.Id"
                                  onsubmit="return confirm('Справді видалити запис?');">
                                <button class="btn btn-sm btn-danger">🗑️</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="alert alert-info shadow-sm">
            <strong>Сумарно:</strong>
            Калорії: <strong class="text-primary">@Model.TotalCalories</strong> ккал |
            Білки: <strong class="text-success">@Model.TotalProteins</strong> г |
            Жири: <strong class="text-warning">@Model.TotalFats</strong> г |
            Вуглеводи: <strong class="text-info">@Model.TotalCarbs</strong> г
        </div>
    }
    else
    {
        <div class="alert alert-secondary">Немає записів на цю дату.</div>
    }
    
    <div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">🎯 Прогрес до денної норми</h5>
    </div>
    <div class="card-body">
        @if (Model.TargetCalories <= 0)
        {
            <div class="alert alert-warning mb-0">
                Ви ще не розрахували денну норму.
                <a asp-page="/NutritionCalculator" class="alert-link">Розрахувати зараз</a>
            </div>
        }
        else
        {
            <div class="row g-4 align-items-center">
                <div class="col-md-4 text-center">
                    <canvas id="calorieGoalChart" width="220" height="220"></canvas>
                </div>
                <div class="col-md-8">
                    @{
                        float pctP = Model.TargetProteins > 0 ? Model.TotalProteins / Model.TargetProteins * 100 : 0;
                        float pctF = Model.TargetFats > 0 ? Model.TotalFats / Model.TargetFats * 100 : 0;
                        float pctC = Model.TargetCarbs > 0 ? Model.TotalCarbs / Model.TargetCarbs * 100 : 0;
                    }
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>Білки</span><span>@Model.TotalProteins / @Model.TargetProteins г</span>
                        </div>
                        <div class="progress"><div class="progress-bar bg-success" style="width:@(Math.Min(pctP,100))%"></div></div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>Жири</span><span>@Model.TotalFats / @Model.TargetFats г</span>
                        </div>
                        <div class="progress"><div class="progress-bar bg-warning" style="width:@(Math.Min(pctF,100))%"></div></div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>Вуглеводи</span><span>@Model.TotalCarbs / @Model.TargetCarbs г</span>
                        </div>
                        <div class="progress"><div class="progress-bar bg-info" style="width:@(Math.Min(pctC,100))%"></div></div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const btn = document.getElementById('btnAiAnalyzeNutrition');
            if (btn) {
                btn.addEventListener('click', async () => {
                    const resultBlock = document.getElementById('aiNutritionResult');
                    const dateInput = document.getElementById('selectedDateInput');
                    const selectedDate = dateInput && dateInput.value
                        ? dateInput.value
                        : new Date().toISOString().split('T')[0];
                    btn.disabled = true;
                    btn.innerHTML = `<span class="spinner-border spinner-border-sm"></span> ⏳ Аналіз...`;

                    document.getElementById('aiBalanceVerdict').innerHTML =
                        `<span class="spinner-grow spinner-grow-sm text-info"></span> Обробка...`;
                    document.getElementById('aiMicronutrientsNotes').innerHTML =
                        `<span class="spinner-grow spinner-grow-sm text-warning"></span> Звірка...`;
                    document.getElementById('aiRecommendationForDinner').innerHTML =
                        `<span class="spinner-grow spinner-grow-sm text-success"></span> Генерація...`;
                    resultBlock.style.display = 'block';

                    try {
                        const apiUrl = "@Model.ApiBaseUrl";
                        const jwtToken = "@Model.JwtToken";
                        const response = await fetch(`${apiUrl}/api/AI/analyze-daily-nutrition?date=${selectedDate}`, {
                            method: 'GET',
                            headers: {
                                'Authorization': `Bearer ${jwtToken}`,
                                'Accept': 'application/json'
                            }
                        });

                        if (!response.ok)
                            throw new Error(`Помилка сервера: ${response.status}`);

                        const data = await response.json();
                        document.getElementById('aiBalanceVerdict').innerText =
                            data.balanceVerdict || "Дані відсутні";
                        document.getElementById('aiMicronutrientsNotes').innerText =
                            data.micronutrientsNotes || "Дані відсутні";
                        document.getElementById('aiRecommendationForDinner').innerText =
                            data.recommendationForDinner || "Дані відсутні";
                    }
                    catch (err) {
                        console.error(err);
                        document.getElementById('aiBalanceVerdict').innerText = "Помилка з'єднання.";
                        document.getElementById('aiMicronutrientsNotes').innerText = "Не вдалося отримати дані.";
                        document.getElementById('aiRecommendationForDinner').innerText = "Спробуйте пізніше.";
                        alert("Не вдалося виконати AI-аналіз: " + err.message);
                    }
                    finally {
                        btn.disabled = false;
                        btn.innerHTML = "✨ AI-Аналіз дня";
                    }
                });
            }

            const calCanvas = document.getElementById('calorieGoalChart');
            if (calCanvas) {
                const consumed = @Model.TotalCalories;
                const goal = @Model.TargetCalories;
                const remaining = Math.max(goal - consumed, 0);
                const overGoal = Math.max(consumed - goal, 0);
                new Chart(calCanvas, {
                    type: 'doughnut',
                    data: {
                        labels: overGoal > 0
                            ? ['Спожито (норма)', 'Перевищення']
                            : ['Спожито', 'Залишилось'],
                        datasets: [{
                            data: overGoal > 0
                                ? [goal, overGoal]
                                : [consumed, remaining],
                            backgroundColor: overGoal > 0
                                ? ['#0d6efd', '#dc3545']
                                : ['#0d6efd', '#e9ecef'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        cutout: '70%',
                        plugins: {
                            legend: {
                                position: 'bottom'
                            },
                            tooltip: {
                                enabled: true
                            }
                        }
                    },
                    plugins: [{
                        id: 'centerText',
                        afterDraw(chart) {

                            const {
                                ctx,
                                chartArea: { width, height, top, left }
                            } = chart;

                            ctx.save();
                            ctx.font = 'bold 20px sans-serif';
                            ctx.fillStyle = '#212529';
                            ctx.textAlign = 'center';
                            ctx.fillText(`${consumed} / ${goal}`, left + width / 2, top + height / 2);
                            ctx.font = '12px sans-serif';
                            ctx.fillText('ккал', left + width / 2, top + height / 2 + 20);
                            ctx.restore();
                        }
                    }]
                });

            }
        });
    </script>
}