@page "{handler?}"
@model TrainingLibraryModel
@{
    ViewData["Title"] = "Бібліотека тренувань";
}

<div class="container mt-4">
    <h2>📚 Бібліотека тренувальних програм</h2>

    <div class="mb-3">
        @foreach (var pair in new[] {
            new { Ua = "Кардіо", En = "Cardio" },
            new { Ua = "Силові", En = "Strength" },
            new { Ua = "Гнучкість", En = "Flexibility" }
        })
        {
            <a class="btn @(Model.Category?.Equals(pair.En, StringComparison.OrdinalIgnoreCase) == true ? "btn-primary" : "btn-outline-primary") me-2"
               href="?category=@pair.En">@pair.Ua</a>
        }
        <a class="btn @(string.IsNullOrEmpty(Model.Category) ? "btn-secondary" : "btn-outline-secondary")" href="/TrainingLibrary">Усі</a>
    </div>
    
    @{
        var categoryMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            { "Cardio", "Кардіо" },
            { "Strength", "Силові" },
            { "Flexibility", "Гнучкість" }
        };
        
        string GetYoutubeEmbedUrl(string originalUrl)
        {
            if (originalUrl.Contains("shorts/"))
            {
                var id = originalUrl.Split("shorts/")[1].Split('?')[0];
                return $"https://www.youtube.com/embed/{id}";
            }
            else if (originalUrl.Contains("watch?v="))
            {
                var id = originalUrl.Split("watch?v=")[1].Split('&')[0];
                return $"https://www.youtube.com/embed/{id}";
            }
            return originalUrl;
        }
    }

    <h4>🎬 Відео тренувань</h4>
    <div class="row">
        @if (!Model.Videos.Any())
        {
            <div class="col-12"><p class="text-muted">Немає відео в цій категорії.</p></div>
        }
        else
        {
            @foreach (var video in Model.Videos)
            {
                var categoryUa = categoryMap.TryGetValue(video.Category ?? "", out var uaStr) ? uaStr : video.Category;

                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm">
                        <iframe class="card-img-top"
                                src="@GetYoutubeEmbedUrl(video.Url)"
                                allowfullscreen
                                style="aspect-ratio: 16/9; width: 100%; border: none;">
                        </iframe>
                        <div class="card-body">
                            <h5 class="card-title">@video.Title</h5>
                            <p class="card-text"><small class="text-muted">Категорія: @categoryUa</small></p>
                            <p class="card-text"><small class="text-muted">Тривалість: @video.Duration хв</small></p>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <h4 class="mt-5">📋 Тренувальні програми</h4>
    <div class="row">
        <div class="col-12">
            <ul class="list-group shadow-sm">
                @if (!Model.Programs.Any())
                {
                    <li class="list-group-item text-muted">Немає програм в цій категорії.</li>
                }
                else
                {
                    @foreach (var p in Model.Programs)
                    {
                        var categoryUa = categoryMap.TryGetValue(p.Category ?? "", out var uaStr) ? uaStr : p.Category;
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@p.Name</strong> — @p.Description
                            </div>
                            <span class="badge bg-secondary rounded-pill">@categoryUa</span>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>

    <div class="mt-4">
        <a asp-page="/Workouts" class="btn btn-secondary">⬅️ Назад до тренувань</a>
    </div>
</div>